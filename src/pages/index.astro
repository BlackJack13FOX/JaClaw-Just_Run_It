---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- 导航栏 -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-md border-b border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🦞</span>
        <span class="text-xl font-bold text-white">JaClaw</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="#features" class="text-[var(--color-text-muted)] hover:text-white transition">特性</a>
        <a href="/pricing" class="text-[var(--color-text-muted)] hover:text-white transition">价格</a>
        <a href="#download" class="text-[var(--color-text-muted)] hover:text-white transition">下载</a>
        <a href="https://github.com" target="_blank" class="text-[var(--color-text-muted)] hover:text-white transition">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero区域 - 海报背景 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- 海报背景图 -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/bg4.jpg" 
        alt="JaClaw Poster"
        class="w-full h-full object-cover"
      />
      <!-- 遮罩确保文字可读 -->
      <div class="absolute inset-0 bg-[var(--color-bg)]/60"></div>
    </div>
    
    <!-- 渐变光晕效果 -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-[var(--color-accent)]/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-[var(--color-accent-pink)]/20 rounded-full blur-3xl"></div>
    
    <!-- 内容 -->
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6 pt-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-bg-card)]/80 border border-[var(--color-border)] mb-8 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
        <span class="text-sm text-[var(--color-text-muted)]">10,000+ 人在用</span>
      </div>
      
      <h1 class="text-4xl md:text-7xl font-bold mb-6 leading-tight">
        <span class="gradient-text">一键跑</span>
        <br />
        <span class="text-white">AI智能助手</span>
      </h1>
      
      <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed">
        别人还在配环境、调参数、踩坑
        <br />
        <span class="text-[var(--color-accent)] font-semibold">你双击打开就能用AI干活了</span>
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a href="#download" class="btn-gradient px-10 py-5 rounded-2xl font-bold text-lg text-white inline-flex items-center justify-center shadow-lg shadow-orange-500/25">
          开始使用
        </a>
      </div>
      
      <div class="flex flex-wrap justify-center gap-6 text-sm text-[var(--color-text-muted)]">
        <span class="flex items-center gap-2">✅ 3分钟安装</span>
        <span class="flex items-center gap-2">✅ 不用配环境</span>
        <span class="flex items-center gap-2">✅ 密钥不外泄</span>
      </div>
    </div>
    
    <!-- 向下箭头 -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- 特性区域 -->
  <section id="features" class="py-24 px-6 bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">一句话概括</h2>
        <p class="text-[var(--color-text-muted)] text-lg">你不需要懂技术，AI帮你干活</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- 安全 -->
        <div class="card-hover bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[var(--color-accent)]/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
          <h3 class="text-xl font-bold mb-3 text-white">企业级安全防护机制</h3>
          <p class="text-[var(--color-text-muted)] relative z-10">
            密钥出不去，文件管得住，外网找不到
          </p>
          <div class="mt-4 pt-4 border-t border-[var(--color-border)] text-xs text-[var(--color-text-muted)] space-y-2">
            <div class="flex justify-between items-center"><span>网络隐身（VPN）</span><span class="text-green-400">✅ 外人找不到你</span></div>
            <div class="flex justify-between items-center"><span>加密通道 + 身份验证</span><span class="text-green-400">✅ 传输全过程加密</span></div>
            <div class="flex justify-between items-center"><span>普通用户运行</span><span class="text-green-400">✅ 想搞破坏也没权限</span></div>
            <div class="flex justify-between items-center"><span>密钥保险箱</span><span class="text-green-400">✅ AI干活也碰不到密钥</span></div>
            <div class="flex justify-between items-center"><span>文件权限隔离</span><span class="text-green-400">✅ 能做的做，不能动的绝不沾</span></div>
          </div>
        </div>
        
        <!-- 稳定 -->
        <div class="card-hover bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[var(--color-accent)]/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
          <h3 class="text-xl font-bold mb-3 text-white">跑一整天，7×24小时不带崩的</h3>
          <p class="text-[var(--color-text-muted)] relative z-10 mb-4">
            专业级稳定性保障，长时间运行稳如老狗。
          </p>
          <div class="pt-4 border-t border-[var(--color-border)] text-xs text-[var(--color-text-muted)] space-y-2">
            <div class="flex justify-between items-center"><span>长时间稳定测试</span><span class="text-green-400">✅ 通过</span></div>
            <div class="flex justify-between items-center"><span>任务中断自动续接</span><span class="text-green-400">✅ 无需值守</span></div>
            <div class="flex justify-between items-center"><span>后台自动修复</span><span class="text-green-400">✅ 小问题自己修</span></div>
            <div class="flex justify-between items-center"><span>异常告警通知</span><span class="text-green-400">✅ 及时推送</span></div>
          </div>
        </div>
        
        <!-- 简单 -->
        <div class="card-hover bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[var(--color-accent)]/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
          <h3 class="text-xl font-bold mb-3 text-white">小白老登都能用</h3>
          <p class="text-[var(--color-text-muted)] relative z-10 mb-4">
            不用学技术，打开就能用。
          </p>
          <div class="pt-4 border-t border-[var(--color-border)] text-xs text-[var(--color-text-muted)] space-y-2">
            <div class="flex justify-between items-center"><span>安装</span><span class="text-green-400">✅ 双击，3分钟</span></div>
            <div class="flex justify-between items-center"><span>环境</span><span class="text-green-400">✅ 不用Docker</span></div>
            <div class="flex justify-between items-center"><span>操作</span><span class="text-green-400">✅ 不用敲命令</span></div>
            <div class="flex justify-between items-center"><span>密钥</span><span class="text-green-400">✅ 不用自己申请</span></div>
            <div class="flex justify-between items-center"><span>体验</span><span class="text-green-400">✅ 像用微信</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 对比区域 -->
  <section class="py-24 px-6 bg-[var(--color-bg-secondary)]">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4 text-white">别人踩坑，你直接用</h2>
      </div>
      
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-6">
          <div class="text-red-400 font-bold mb-2">❌ 别的AI助手</div>
          <ul class="text-[var(--color-text-muted)] space-y-2 text-sm">
            <li>• 装2小时还没搞定</li>
            <li>• 要配API Key</li>
            <li>• 跑一会就崩</li>
            <li>• 密钥有可能泄露</li>
          </ul>
        </div>
        <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-6">
          <div class="text-green-400 font-bold mb-2">✅ JaClaw</div>
          <ul class="text-white space-y-2 text-sm">
            <li>• 双击，3分钟开始用</li>
            <li>• 不用配，直接跑</li>
            <li>• 跑一整天纹丝不动</li>
            <li>• 密钥加密，保镖级安全</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 下载区域 -->
  <section id="download" class="py-24 px-6 bg-gradient-to-b from-[var(--color-bg)] via-[var(--color-bg-secondary)] to-[var(--color-bg)]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">
        真的，就3分钟
      </h2>
      <p class="text-xl text-[var(--color-text-muted)] mb-10">
        下载 → 双击 → 打开就能用<br/>
        不需要任何配置
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="#" class="btn-gradient px-10 py-5 rounded-2xl font-bold text-lg text-white inline-flex items-center justify-center shadow-lg shadow-orange-500/25 hover:scale-105 transition-transform">
          macOS 下载
        </a>
        <a href="#" class="px-10 py-5 rounded-2xl font-bold text-lg bg-[var(--color-bg-card)] border border-[var(--color-border)] hover:border-[var(--color-accent)] transition inline-flex items-center justify-center hover:scale-105 transition-transform">
          Windows 下载
        </a>
      </div>
      
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-[var(--color-bg-card)] rounded-full border border-[var(--color-border)]">
        <span class="text-[var(--color-text-muted)]">免费试用3天 · 不满意随时停</span>
      </div>
    </div>
  </section>

  <!-- 页脚 -->
  <footer class="py-10 px-6 border-t border-[var(--color-border)] bg-[var(--color-bg)]">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-xl">🦞</span>
        <span class="font-semibold text-white">JaClaw</span>
      </div>
      <p class="text-sm text-[var(--color-text-muted)]">
        © 2026 JaClaw. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="#" class="text-[var(--color-text-muted)] hover:text-white transition">隐私政策</a>
        <a href="#" class="text-[var(--color-text-muted)] hover:text-white transition">服务条款</a>
        <a href="#" class="text-[var(--color-text-muted)] hover:text-white transition">联系我们</a>
      </div>
    </div>
  </footer>
</Layout>
